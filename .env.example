# MCP 聚合网关密钥存储示例
# 请复制此文件为 .env 并填写您真实的密钥

# 网关统一访问密钥（客户端请求网关时需携带，支持逗号分隔配置多个）
GATEWAY_ACCESS_KEYS=your-gateway-access-key-1,your-gateway-access-key-2

# 各服务的上游密钥池（支持逗号分隔配置多个，自动轮询负载均衡）
SERVICE_KEYS_context7=ctx7sk-your-key-1,ctx7sk-your-key-2
SERVICE_KEYS_tavily=tvly-dev-your-key-1,tvly-dev-your-key-2
